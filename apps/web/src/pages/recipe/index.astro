---
import "@workspace/ui/globals.css"
import type { Recipe } from "@/lib/types"
import { IngredientList } from "@/components/ingredient-list"
import { formatDuration } from "@/lib/duration"
import { getLiveEntry } from "astro:content"

// ── Resolve the recipe URL from query param ───────────────────────────────────
const rawUrl = Astro.url.searchParams.get("url")

if (!rawUrl) {
  return Astro.redirect("/")
}

let recipeUrl: string
try {
  recipeUrl = decodeURIComponent(rawUrl)
  new URL(recipeUrl) // validate
} catch {
  return Astro.redirect("/")
}

// ── Load via live loader (KV cache → scrape → persist) ────────────────────────
const { entry, error } = await getLiveEntry("recipes", recipeUrl)

const recipe: Recipe | null =
  !error && entry ? (entry.data as Recipe) : null
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="https://fav.farm/🍽️" />
    <title>{recipe ? recipe.title : "Recipe"} — Meal Prep</title>
  </head>
  <body>
    <div class="mx-auto max-w-2xl px-6 py-12">
      <a
        href="/"
        class="mb-8 inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        &larr; Back
      </a>

      {
        !recipe ? (
          <div class="flex flex-col gap-2">
            <h1 class="text-xl font-semibold">Could not extract recipe</h1>
            <p class="text-sm text-muted-foreground">
              We weren't able to find a recipe at{" "}
              <a
                href={recipeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="underline"
              >
                {recipeUrl}
              </a>
              . The site may not publish structured data and our AI extraction
              may have failed.
            </p>
          </div>
        ) : (
          <article class="flex flex-col gap-8">
            {recipe.imageUrl && (
              <img
                src={recipe.imageUrl}
                alt={recipe.title}
                class="aspect-video w-full rounded-lg object-cover"
              />
            <header class="text-xs text-muted-foreground">
              <a
                href={recipeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="underline transition-colors hover:text-foreground"
              >
                View original recipe
              </a>
            </header>
            )}

            <div class="flex flex-col gap-2">
              <h1 class="text-2xl font-semibold tracking-tight">
                {recipe.title}
              </h1>
              {recipe.description && (
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {recipe.description}
                </p>
              )}
            </div>

            {(recipe.prepTime ||
              recipe.cookTime ||
              recipe.totalTime ||
              recipe.servings) && (
              <dl class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                {recipe.prepTime && (
                  <div class="rounded-md bg-muted px-3 py-2">
                    <dt class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
                      Prep
                    </dt>
                    <dd class="mt-0.5 text-sm font-medium">
                      {formatDuration(recipe.prepTime)}
                    </dd>
                  </div>
                )}
                {recipe.cookTime && (
                  <div class="rounded-md bg-muted px-3 py-2">
                    <dt class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
                      Cook
                    </dt>
                    <dd class="mt-0.5 text-sm font-medium">
                      {formatDuration(recipe.cookTime)}
                    </dd>
                  </div>
                )}
                {recipe.totalTime && (
                  <div class="rounded-md bg-muted px-3 py-2">
                    <dt class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
                      Total
                    </dt>
                    <dd class="mt-0.5 text-sm font-medium">
                      {formatDuration(recipe.totalTime)}
                    </dd>
                  </div>
                )}
                {recipe.servings && (
                  <div class="rounded-md bg-muted px-3 py-2">
                    <dt class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
                      Serves
                    </dt>
                    <dd class="mt-0.5 text-sm font-medium">
                      {recipe.servings}
                    </dd>
                  </div>
                )}
              </dl>
            )}

            <section>
              <h2 class="mb-3 text-base font-semibold">Ingredients</h2>
              <IngredientList ingredients={recipe.ingredients} client:load />
            </section>

            <section>
              <h2 class="mb-3 text-base font-semibold">Instructions</h2>
              <ol class="flex flex-col gap-4">
                {recipe.instructions.map((step, i) => (
                  <li class="flex gap-3 text-sm">
                    <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-medium text-primary-foreground">
                      {i + 1}
                    </span>
                    <span class="leading-relaxed">{step}</span>
                  </li>
                ))}
              </ol>
            </section>

          </article>
        )
      }
    </div>
  </body>
</html>
