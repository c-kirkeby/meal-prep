---
import "@workspace/ui/globals.css"
import { RecipeForm } from "@/components/RecipeForm"
import { RecipeCarousel } from "@/components/RecipeCarousel"
import { getLiveCollection } from "astro:content"

const { entries, error } = await getLiveCollection("recipes", { limit: 10 })

const recentRecipes =
  !error && entries
    ? entries
        .filter((e): e is typeof e & { data: { title: string } } =>
          typeof e.data.title === "string"
        )
        .map((e) => ({
          url: e.id,
          title: e.data.title,
          imageUrl: e.data.imageUrl,
        }))
    : []
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Meal Prep</title>
  </head>
  <body>
    <div class="flex min-h-svh items-center justify-center p-6">
      <div class="flex w-full max-w-xl flex-col gap-8">
        <div class="flex flex-col gap-4">
          <div class="flex flex-col gap-1">
            <h1 class="text-center text-3xl font-semibold tracking-tight">
              Save a Recipe
            </h1>
            <p class="text-center text-muted-foreground">
              Paste a link to save your favourite recipes.
            </p>
          </div>
          <RecipeForm client:load />
        </div>

        {
          recentRecipes.length > 0 && (
            <RecipeCarousel recipes={recentRecipes} client:load />
          )
        }
      </div>
    </div>
  </body>
</html>
